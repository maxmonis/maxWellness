{
  "name": "workout-app",
  "description": "MERN stack fitness tracker",
  "version": "0.1.0",
  "engines": {
    "node": "14.x",
    "yarn": "1.x"
  },
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"yarn:serve\" \"cd app && yarn start\"",
    "devsetup": "yarn install && cd app && yarn install",
    "start": "node server.js",
    "serve": "nodemon server.js",
    "heroku-postbuild": "cd app && yarn install && yarn build"
  },
  "keywords": [],
  "author": "Max Monis",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "config": "^3.2.6",
    "express": "^4.17.3",
    "express-validator": "^6.4.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^5.9.2"
  },
  "devDependencies": {
    "concurrently": "^7.0.0",
    "nodemon": "^2.0.2"
  }
}
